# EmbraceGrafanaDemo — native iOS (Swift) client · FNB-96526
# CocoaPods 1.16.2 · iOS 13 deploy target · Xcode 26.5.
#
# Pins match the proven Flutter iOS integration's Podfile.lock (EmbraceIO 6.20.0 →
# OpenTelemetry-Swift 2.5.0). We list the two OTel pods explicitly so the plain-OTel
# arm can `import OpenTelemetryApi` / `import OpenTelemetrySdk` directly (the same
# OTLP/JSON exporter we hand to Embrace.Options(export:) also feeds the OTel arm).

platform :ios, '13.0'
use_frameworks!

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

target 'EmbraceDemo' do
  pod 'EmbraceIO', '6.20.0'
  pod 'OpenTelemetry-Swift-Api', '2.5.0'
  pod 'OpenTelemetry-Swift-Sdk', '2.5.0'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # Defend against pods defaulting to a deployment target higher than the app.
      # 13.0 >= every pod's own minimum here, so this is always safe.
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      # NOTE: deliberately NO EXCLUDED_ARCHS arm64 — on Apple Silicon + Xcode 26.5
      # the arm64 simulator slice is required. Do not re-add the legacy hack.
    end
  end
end
